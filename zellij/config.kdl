// Zellij configuration
// Docs: https://zellij.dev/documentation/

// Custom Tokyo Night with a high-contrast active-pane frame so it's always
// obvious which pane is focused and where its borders are (see themes block).
theme "tokyo-night-frames"
// default_shell is intentionally unset: Zellij inherits the shell WezTerm
// launched via `default_prog` (zsh on Linux, pwsh on Windows), so this one
// config works on both platforms.
default_layout "compact"

pane_frames true
mouse_mode true
copy_on_select true
// copy_command is intentionally unset: copy goes through the terminal's OSC52
// clipboard (WezTerm supports it on Linux and Windows). If a corner case fails,
// set a per-OS fallback: "wl-copy" (Wayland), "xclip -selection clipboard" (X11),
// or "clip" (Windows).
show_startup_tips true
scrollback_editor "nvim"

ui {
    pane_frames {
        rounded_corners true
        hide_session_name false
    }
}

// Tokyo Night, but with `frame_selected` bumped to bright blue (#7aa2f7) so the
// focused pane's border pops against the dim inactive frames. Everything else
// mirrors the built-in tokyo-night-dark palette.
themes {
    tokyo-night-frames {
        text_unselected {
            base "#a9b1d6"
            background "#1a1b26"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        text_selected {
            base "#a9b1d6"
            background "#292e42"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        ribbon_selected {
            base "#1a1b26"
            background "#7aa2f7"
            emphasis_0 "#f7768e"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        ribbon_unselected {
            base "#1a1b26"
            background "#a9b1d6"
            emphasis_0 "#f7768e"
            emphasis_1 "#16161e"
            emphasis_2 "#bb9af7"
            emphasis_3 "#449dab"
        }
        table_title {
            base "#9ece6a"
            background "#1a1b26"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        table_cell_selected {
            base "#a9b1d6"
            background "#292e42"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        table_cell_unselected {
            base "#a9b1d6"
            background "#1a1b26"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        list_selected {
            base "#a9b1d6"
            background "#292e42"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        list_unselected {
            base "#a9b1d6"
            background "#1a1b26"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        frame_selected {
            base "#7aa2f7"
            background "#1a1b26"
            emphasis_0 "#7dcfff"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        frame_highlight {
            base "#ff9e64"
            background "#1a1b26"
            emphasis_0 "#ff9e64"
            emphasis_1 "#bb9af7"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        exit_code_success {
            base "#9ece6a"
            background "#1a1b26"
            emphasis_0 "#7aa2f7"
            emphasis_1 "#7dcfff"
            emphasis_2 "#bb9af7"
            emphasis_3 "#449dab"
        }
        exit_code_error {
            base "#f7768e"
            background "#1a1b26"
            emphasis_0 "#ff9e64"
            emphasis_1 "#1a1b26"
            emphasis_2 "#449dab"
            emphasis_3 "#9ece6a"
        }
        multiplayer_user_colors {
            player_1 "#bb9af7"
            player_2 "#7dcfff"
            player_3 "#1a1b26"
            player_4 "#e0af68"
            player_5 "#449dab"
            player_6 "#1a1b26"
            player_7 "#f7768e"
            player_8 "#1a1b26"
            player_9 "#1a1b26"
            player_10 "#1a1b26"
        }
    }
}
